# Copy to .env (mode 600) and fill in real values before `docker compose up`.

# ----- Apollo MCP service-account auth -----
# Web Service Access Token generated in the ANET Admin UI under
# "Web service access tokens". Required: apollo-mcp will not start without this.
ANET_GRAPHQL_TOKEN=

# Where Apollo MCP reaches ANET's /graphqlWebService endpoint.
# Default below works when ANET runs on the same host on port 8080.
ANET_GRAPHQL_ENDPOINT=http://host.docker.internal:8080/graphqlWebService

# ----- mcp-ui per-user auth -----
# Where mcp-ui reaches ANET's user-facing /graphql endpoint. Calls are made
# with the caller's bearer token (injected via the iframe<->ANET handshake).
MCP_UI_GRAPHQL_URL=http://host.docker.internal:8080/graphql

# ----- mcp-ui query-parser agent (OpenAI-compatible LLM) -----
# Used by the report-search tool to turn a natural-language query into
# structured search filters. Point this at the same LLM AssistantService uses
ANET_AGENT_BASE_URL=http://ai2.datascienceai.nsf/llm
ANET_AGENT_API_KEY=
ANET_AGENT_MODEL=gpt-4o-dsai

# Apollo MCP server release tag (vendor image).
APOLLO_MCP_TAG=latest
